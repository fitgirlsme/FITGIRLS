{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "**/*.xml",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/xml; charset=utf-8"
          }
        ]
      },
      {
        "source": "/admin?(/**)",
        "headers": [
          {
            "key": "X-Robots-Tag",
            "value": "noindex,nofollow"
          }
        ]
      },
      {
        "source": "/retouch?(/**)",
        "headers": [
          {
            "key": "X-Robots-Tag",
            "value": "noindex,nofollow"
          }
        ]
      },
      {
        "source": "/checklist?(/**)",
        "headers": [
          {
            "key": "X-Robots-Tag",
            "value": "noindex,nofollow"
          }
        ]
      }
    ]
  }
}
